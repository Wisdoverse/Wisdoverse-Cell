# ==============================================================================
# Wisdoverse Cell — Unified Multi-Target Agent Dockerfile
# ==============================================================================
#
# Single Dockerfile for all Python agent images. Docker Compose selects
# the final target via `target:` in the service build config.
#
# Shared stages (builder-base, runtime-base) are built ONCE and reused,
# cutting cold-build time roughly in half and enabling pip cache sharing.
#
# Targets:
#   ai-core          - requirement manager agent (port 8000 + gRPC 50051)
#   sync-agent       - sync support capability (port 8010)
#   analysis-agent   - analysis support capability (port 8011)
#   pjm-agent        - PJM business runtime agent (port 8012)
#   chat-agent       - user interaction gateway runtime id (port 8013)
#   qa-agent         - QA business runtime agent (port 8014)
#   dev-agent        - Dev business runtime agent (port 8015)
#
# Build examples:
#   docker compose build                       # all agents
#   docker compose build sync-agent            # single service target
#   docker build --target sync-agent -f docker/Dockerfile.agents .
#
# ==============================================================================

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SHARED BUILDER BASE — built ONCE, reused by all agent builders         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
FROM python:3.13-slim AS builder-base

ARG PIP_DISABLE_PIP_VERSION_CHECK=1

# CN mirror support — pass via --build-arg or docker compose .env
# pip reads PIP_INDEX_URL and PIP_TRUSTED_HOST from env automatically
ARG PIP_INDEX_URL=https://pypi.org/simple
ARG PIP_TRUSTED_HOST
ARG APT_MIRROR

WORKDIR /build

# hadolint ignore=SC2086
RUN if [ -n "$APT_MIRROR" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install shared runtime dependencies (used by all agents via shared/).
# Keep dev/test tooling in root requirements.txt; production images use this
# Docker-specific runtime baseline plus each service's own requirements file.
COPY docker/requirements/agent-base.txt /build/requirements-base.txt
# BuildKit cache mount — not stored in image layer, speeds up rebuilds
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements-base.txt; \
    else \
      pip install -r requirements-base.txt; \
    fi


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  PER-AGENT BUILDER STAGES — pip install with shared cache mount         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- ai-core (requirement manager agent) --------------------------------------
FROM builder-base AS ai-core-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
ARG INSTALL_VECTOR_DEPS=false
COPY agents/requirement_manager/requirements.txt .
COPY agents/requirement_manager/requirements-vector.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi && \
    if [ "$INSTALL_VECTOR_DEPS" = "true" ]; then \
      if [ -n "$PIP_INDEX_URL" ]; then \
        pip install -i "$PIP_INDEX_URL" -r requirements-vector.txt; \
      else \
        pip install -r requirements-vector.txt; \
      fi; \
    fi

# --- sync-agent --------------------------------------------------------------
FROM builder-base AS sync-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY shared/capabilities/sync/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi

# --- analysis-agent ----------------------------------------------------------
FROM builder-base AS analysis-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY shared/capabilities/analysis/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi

# --- pjm-agent ----------------------------------------------------------------
FROM builder-base AS pm-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY agents/pjm_agent/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi

# --- qa-agent ----------------------------------------------------------------
FROM builder-base AS qa-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY agents/qa_agent/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi

# --- dev-agent ---------------------------------------------------------------
FROM builder-base AS dev-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY agents/dev_agent/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi

# --- chat-agent --------------------------------------------------------------
FROM builder-base AS chat-builder
ARG PIP_INDEX_URL=https://pypi.org/simple
COPY services/gateways/user_interaction/requirements.txt .
# hadolint ignore=DL3042
RUN --mount=type=cache,target=/root/.cache/pip \
    if [ -n "$PIP_INDEX_URL" ]; then \
      pip install -i "$PIP_INDEX_URL" -r requirements.txt; \
    else \
      pip install -r requirements.txt; \
    fi


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SHARED RUNTIME BASE — built ONCE, reused by all final stages           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
FROM python:3.13-slim AS runtime-base

ARG APT_MIRROR

RUN groupadd --gid 1000 appgroup \
    && useradd --uid 1000 --gid appgroup --shell /bin/bash --create-home appuser

# hadolint ignore=SC2086
RUN if [ -n "$APT_MIRROR" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
    libpq5 tini curl \
    && rm -rf /var/lib/apt/lists/* && apt-get clean

WORKDIR /app

ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    APP_ENV=production \
    DEBUG=false

ENTRYPOINT ["/usr/bin/tini", "--"]


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  FINAL TARGETS                                                          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# =============================================================================
# ai-core  (requirement manager agent)
# =============================================================================
FROM runtime-base AS ai-core

ARG VERSION=dev
ARG BUILD_DATE
ARG GIT_COMMIT

LABEL org.opencontainers.image.title="Requirement Manager Agent (ai-core runtime id)" \
      org.opencontainers.image.description="Requirements extraction, confirmation, and PRD generation agent" \
      org.opencontainers.image.vendor="Wisdoverse Cell" \
      org.opencontainers.image.source="https://github.com/Wisdoverse/project-cell" \
      org.opencontainers.image.licenses="LicenseRef-Wisdoverse-Cell-BSL-1.1" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${GIT_COMMIT}"

COPY --from=ai-core-builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH" \
    API_HOST=0.0.0.0 \
    API_PORT=8000

COPY --chown=appuser:appgroup shared/ /app/shared/
COPY --chown=appuser:appgroup skills/ /app/skills/
COPY --chown=appuser:appgroup agents/requirement_manager/ /app/agents/requirement_manager/
COPY --chown=appuser:appgroup alembic.ini /app/alembic.ini
COPY --chown=appuser:appgroup migrations/ /app/migrations/
RUN mkdir -p /app/data && chown appuser:appgroup /app/data

USER appuser
EXPOSE 8000 50051

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl --fail --silent http://localhost:8000/health/ready || exit 1

CMD ["gunicorn", \
     "agents.requirement_manager.app.main:app", \
     "--worker-class", "uvicorn.workers.UvicornWorker", \
     "--workers", "1", \
     "--bind", "0.0.0.0:8000", \
     "--timeout", "120", \
     "--graceful-timeout", "30", \
     "--keep-alive", "5", \
     "--access-logfile", "-", \
     "--access-logformat", "%(h)s %(l)s %(u)s %(t)s \"%(r)s\" %(s)s %(b)s %(D)s"]


