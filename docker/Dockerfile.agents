# ==============================================================================
# Wisdoverse Cell — Unified Python Agent Runtime Image
# ==============================================================================
#
# A single Python runtime image bundles every agent and capability module so
# one tagged release artifact can back every container in the compose
# topology. Compose services choose which agent or module to start by passing
# its name as the first argument (e.g. `command: ["sync-module"]`) or via
# `WISDOVERSE_AGENT`. See `docker/agents-entrypoint.sh` for the full
# selector contract.
#
# Build:
#   docker build -t wisdoverse/cell-agents:dev -f docker/Dockerfile.agents .
# Run:
#   docker run --rm wisdoverse/cell-agents:dev sync-module
#   docker run --rm wisdoverse/cell-agents:dev help
#
# ==============================================================================

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  BUILDER — install every agent's runtime dependencies once               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
FROM python:3.14-slim AS builder

ARG PIP_DISABLE_PIP_VERSION_CHECK=1
ARG PIP_INDEX_URL=https://pypi.org/simple
ARG PIP_TRUSTED_HOST
ARG APT_MIRROR
ARG INSTALL_VECTOR_DEPS=false

WORKDIR /build

# hadolint ignore=SC2086
RUN if [ -n "$APT_MIRROR" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
      gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Layered requirements: base first (warmest cache), then per-agent on top.
COPY docker/requirements/agent-base.txt /build/requirements-base.txt
COPY agents/requirement_manager/requirements.txt /build/requirements-ai-core.txt
COPY agents/requirement_manager/requirements-vector.txt /build/requirements-ai-core-vector.txt
COPY shared/capabilities/sync/requirements.txt /build/requirements-sync.txt
COPY shared/capabilities/analysis/requirements.txt /build/requirements-analysis.txt
COPY shared/capabilities/evolution/requirements.txt /build/requirements-evolution.txt
COPY agents/pjm_agent/requirements.txt /build/requirements-pjm.txt
COPY agents/qa_agent/requirements.txt /build/requirements-qa.txt
COPY agents/dev_agent/requirements.txt /build/requirements-dev.txt
COPY services/gateways/user_interaction/requirements.txt /build/requirements-chat.txt

# hadolint ignore=DL3042,SC2086
RUN --mount=type=cache,target=/root/.cache/pip \
    PIP_INDEX_ARGS="" && \
    if [ -n "$PIP_INDEX_URL" ]; then \
      PIP_INDEX_ARGS="$PIP_INDEX_ARGS -i $PIP_INDEX_URL"; \
    fi && \
    if [ -n "$PIP_TRUSTED_HOST" ]; then \
      PIP_INDEX_ARGS="$PIP_INDEX_ARGS --trusted-host $PIP_TRUSTED_HOST"; \
    fi && \
    pip install $PIP_INDEX_ARGS -r /build/requirements-base.txt && \
    pip install $PIP_INDEX_ARGS \
      -r /build/requirements-ai-core.txt \
      -r /build/requirements-sync.txt \
      -r /build/requirements-analysis.txt \
      -r /build/requirements-evolution.txt \
      -r /build/requirements-pjm.txt \
      -r /build/requirements-qa.txt \
      -r /build/requirements-dev.txt \
      -r /build/requirements-chat.txt && \
    if [ "$INSTALL_VECTOR_DEPS" = "true" ]; then \
      pip install $PIP_INDEX_ARGS -r /build/requirements-ai-core-vector.txt; \
    fi


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  RUNTIME — single final image with every agent + module bundled         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
FROM python:3.14-slim AS runtime

ARG VERSION=dev
ARG BUILD_DATE
ARG GIT_COMMIT
ARG APT_MIRROR

LABEL org.opencontainers.image.title="Wisdoverse Cell — Agents" \
      org.opencontainers.image.description="Unified Python runtime image bundling every Wisdoverse Cell agent and support capability. The first command argument selects which one to launch (ai-core, sync-module, analysis-module, evolution-module, pjm-agent, qa-agent, dev-agent, chat-agent)." \
      org.opencontainers.image.vendor="Wisdoverse Cell" \
      org.opencontainers.image.source="https://github.com/Wisdoverse/Wisdoverse-Cell" \
      org.opencontainers.image.licenses="LicenseRef-Wisdoverse-Cell-BSL-1.1" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${GIT_COMMIT}"

# hadolint ignore=SC2086
RUN if [ -n "$APT_MIRROR" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
      libpq5 tini curl \
    && rm -rf /var/lib/apt/lists/* && apt-get clean

RUN groupadd --gid 1000 appgroup \
    && useradd --uid 1000 --gid appgroup --shell /bin/bash --create-home appuser

WORKDIR /app

ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    APP_ENV=production \
    DEBUG=false \
    PATH="/opt/venv/bin:$PATH"

COPY --from=builder /opt/venv /opt/venv

# Copy every agent and capability so the same image can play any role.
COPY --chown=appuser:appgroup shared/   /app/shared/
COPY --chown=appuser:appgroup skills/   /app/skills/
COPY --chown=appuser:appgroup agents/   /app/agents/
COPY --chown=appuser:appgroup services/ /app/services/
COPY --chown=appuser:appgroup alembic.ini    /app/alembic.ini
COPY --chown=appuser:appgroup migrations/    /app/migrations/
COPY --chown=appuser:appgroup .acceptance/   /app/.acceptance/
COPY --chown=appuser:appgroup docker/agents-entrypoint.sh /usr/local/bin/wisdoverse-agent
COPY --chown=appuser:appgroup docker/cell-supervisor.py /usr/local/bin/wisdoverse-cell-supervisor

RUN chmod +x /usr/local/bin/wisdoverse-agent && \
    mkdir -p /app/data && chown appuser:appgroup /app/data

USER appuser

# Python service ports kept stable for compatibility with operator runbooks.
EXPOSE 8000 8010 8011 8012 8013 8014 8015 8016 50051

# Default to a soft help target; concrete services pass the role as `command`.
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl --fail --silent "http://localhost:${WISDOVERSE_BIND_PORT:-8000}/health/ready" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/wisdoverse-agent"]
CMD ["help"]
