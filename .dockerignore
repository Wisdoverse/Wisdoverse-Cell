# ==============================================================================
# Wisdoverse Cell - Docker Build Ignore
# ==============================================================================
# Reduces build context size and prevents sensitive files from entering images

# ------------------------------------------------------------------------------
# Version Control
# ------------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# ------------------------------------------------------------------------------
# Dependencies (rebuilt in container)
# ------------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Rust build artifacts
target/
rust/target/
**/target/

# ------------------------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ------------------------------------------------------------------------------
# Environment & Secrets (NEVER include in image!)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
tests/
**/tests/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ------------------------------------------------------------------------------
# Documentation (not needed at runtime)
# ------------------------------------------------------------------------------
docs/
*.md
!README.md

# ------------------------------------------------------------------------------
# Local Development
# ------------------------------------------------------------------------------
.ai_context/
.claude/
.playwright-mcp/
.ralph/
.remember/
.worktrees/
.mise.toml
.tool-versions
Makefile
docker-compose*.yml
*.log
*.tmp
data/
logs/

# ------------------------------------------------------------------------------
# CI/CD
# ------------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile

# ------------------------------------------------------------------------------
# OS Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Cloud-native config (not needed in app images)
# ------------------------------------------------------------------------------
docker/compose/
docker/traefik/
docker/nats/
docker/pgbouncer/
docker/postgres/
docker/redis/
docker/grafana/
docker/loki/
docker/tempo/
docker/promtail/
docker/prometheus/

# ------------------------------------------------------------------------------
# Frontend (rebuilt in container)
# ------------------------------------------------------------------------------
frontend/node_modules
frontend/.next
frontend/.env.local
frontend/next-env.d.ts
frontend/tsconfig.tsbuildinfo
