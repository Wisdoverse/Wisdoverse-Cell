# ==============================================================================
# China mainland build mirror example
# ==============================================================================
#
# Usage:
#   cp .env.example .env
#   cat docs/examples/cn-build-mirrors.env.example >> .env
#
# Or pass it explicitly for local builds:
#   docker compose \
#     --env-file .env \
#     --env-file docs/examples/cn-build-mirrors.env.example \
#     build
#
# This file only affects dependency download mirrors during local/container
# builds. It is not required for runtime containers.
# ==============================================================================

# Python (pip)
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Debian (apt)
APT_MIRROR=mirrors.aliyun.com

# Alpine (apk)
ALPINE_MIRROR=mirrors.aliyun.com

# Go modules
GOPROXY=https://goproxy.cn,direct

# Node.js (npm)
NPM_REGISTRY=https://registry.npmmirror.com
