# ==============================================================================
# Wisdoverse Cell - Git Ignore Configuration
# ==============================================================================
#
# Organized by category for easy maintenance.
# See: https://github.com/github/gitignore for templates
#
# ==============================================================================

# ------------------------------------------------------------------------------
# SECRETS & CREDENTIALS (CRITICAL - Never commit!)
# ------------------------------------------------------------------------------
# Environment files with secrets
.env
.env.*
.env.local
.env.*.local
.env.production
.env.staging
!.env.example

# API keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Cloud credentials
credentials.json
service-account*.json
*.credentials
gcp-key.json
aws-credentials

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ------------------------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------------------------
# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Cython debug symbols
cython_debug/

# ------------------------------------------------------------------------------
# TESTING & COVERAGE
# ------------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
test-results/
junit*.xml

# ------------------------------------------------------------------------------
# IDE & EDITORS
# ------------------------------------------------------------------------------
# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/
*.code-workspace

# Vim/Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# Cursor
.cursor/

# ------------------------------------------------------------------------------
# BUILD & ARTIFACTS
# ------------------------------------------------------------------------------
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker (root-level override only; docker/compose/ overrides are tracked)
/docker-compose.override.yml

# Database files
*.db
*.sqlite
*.sqlite3
*.db-journal

# ------------------------------------------------------------------------------
# PROJECT SPECIFIC
# ------------------------------------------------------------------------------
# Data directories (may contain sensitive data)
data/
!data/.gitkeep

# Local configuration
.mise.toml
.tool-versions
.nvmrc
.node-version

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# ------------------------------------------------------------------------------
# OPERATING SYSTEM
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ------------------------------------------------------------------------------
# AI & DEVELOPMENT TOOLS
# ------------------------------------------------------------------------------
# Agent-only/private automation context
.ai_context/
.ralph/
.remember/

# Private planning/review archives are intentionally not published.
docs/plans/
docs/reviews/
docs/archive/

# Claude Code
.claude/

# Git Worktrees (isolated development)
.worktrees/

# GitHub Copilot
.copilot/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# DOCUMENTATION (optional - uncomment if needed)
# ------------------------------------------------------------------------------
# Sphinx documentation
# docs/_build/

# mkdocs documentation
# /site
