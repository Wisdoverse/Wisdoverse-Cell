# ==============================================================================
# Wisdoverse Cell - Environment Configuration
# ==============================================================================
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Fill in required values (marked with [REQUIRED])
#   3. Adjust optional values as needed
#   4. Start services: docker compose up -d
#
# Environments:
#   - development: Local development with debug enabled
#   - staging:     Pre-production testing
#   - production:  Live environment (never commit .env for this!)
#
# Security:
#   - NEVER commit .env files to version control
#   - Use secrets management (Vault, AWS Secrets Manager) in production
#   - Rotate credentials regularly
#
# ==============================================================================

# ------------------------------------------------------------------------------
# DOCKER COMPOSE - Container Configuration
# ------------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=projectcell
VERSION=latest
# Optional: Docker registry prefix
REGISTRY=

# ------------------------------------------------------------------------------
# BUILD MIRRORS - CN acceleration (leave empty for international defaults)
# ------------------------------------------------------------------------------
# For China mainland, copy values from:
#   docs/examples/cn-build-mirrors.env.example
#
# PIP_INDEX_URL=                                    # CN: https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=                                 # CN: pypi.tuna.tsinghua.edu.cn
# APT_MIRROR=                                       # CN: mirrors.aliyun.com
# ALPINE_MIRROR=                                    # CN: mirrors.aliyun.com
# NPM_REGISTRY=                                     # CN: https://registry.npmmirror.com

# Replica Configuration
AI_CORE_REPLICAS=3                                  # Number of requirement manager agent instances (ai-core runtime id)
GATEWAY_REPLICAS=3                                  # Number of Gateway instances
SYNC_MODULE_REPLICAS=1                              # Number of sync support capability module instances
ANALYSIS_MODULE_REPLICAS=1                          # Number of analysis support capability module instances
EVOLUTION_MODULE_REPLICAS=1                         # Number of evolution support capability module instances

# Ports (Cloud-Native)
HTTP_PORT=80                                        # Traefik HTTP entry
HTTPS_PORT=443                                     # Traefik HTTPS entry (production overlay)
GRPC_PORT=50051                                     # Traefik gRPC entry
# Let's Encrypt account email for production HTTPS.
# [REQUIRED in production]
TRAEFIK_ACME_EMAIL=

# ------------------------------------------------------------------------------
# INFRASTRUCTURE - External Services
# ------------------------------------------------------------------------------

# PostgreSQL Database [REQUIRED]
# Local: localhost | Docker: host.docker.internal | Production: your-db-host
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=projectcell
POSTGRES_USER=cell
# [REQUIRED] Set a strong password
POSTGRES_PASSWORD=

# Business runtime agent database passwords
# [REQUIRED in production]
CHAT_AGENT_DB_PASSWORD=
# [REQUIRED in production]
PM_AGENT_DB_PASSWORD=
# [REQUIRED in production]
QA_AGENT_DB_PASSWORD=
# [REQUIRED in production]
DEV_AGENT_DB_PASSWORD=

# Support capability module database passwords.
# PostgreSQL role and table names remain *_agent for migration compatibility.
# [REQUIRED in production]
SYNC_MODULE_DB_PASSWORD=
# [REQUIRED in production]
ANALYSIS_MODULE_DB_PASSWORD=
# [REQUIRED in production]
EVOLUTION_MODULE_DB_PASSWORD=

# Optional per-service DB users. Defaults intentionally remain *_agent because
# the database contract has not been migrated.
# SYNC_MODULE_DB_USER=sync_agent
# ANALYSIS_MODULE_DB_USER=analysis_agent
# EVOLUTION_MODULE_DB_USER=evolution_agent

POSTGRES_REPLICATION_PASSWORD=replicator        # Replication user password (change in prod!)

# Redis Cache & Message Queue
# Used for: Event bus, session cache, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Leave empty if no auth required
REDIS_PASSWORD=

# Event Bus Backend
EVENT_BUS_BACKEND=redis                        # "nats" | "redis" (default: redis)
# NATS durable consumer name; defaults to OTEL_SERVICE_NAME
EVENT_BUS_CONSUMER_NAME=
EVENT_BUS_PENDING_CLAIM_IDLE_MS=360000         # Redis Streams: reclaim pending messages idle for this long
EVENT_BUS_PENDING_CLAIM_COUNT=10               # Redis Streams: max pending messages reclaimed per poll
EVENT_BUS_PROCESSED_EVENT_TTL_SECONDS=604800   # Redis Streams: remember processed event IDs for replay idempotency
EVENT_BUS_PROCESSING_LOCK_TTL_SECONDS=360      # Redis Streams: in-flight event lock TTL

# NATS JetStream (Event Bus)
# Used for: Event-driven communication between runtime services
NATS_URL=nats://nats-1:4222,nats://nats-2:4222,nats://nats-3:4222
NATS_STREAM_REPLICAS=3                         # Use 1 for single-node local NATS

# Database Read Replica (optional, for read/write split)
# DB_READ_HOST=pg-replica                      # Set to enable read replica routing
# DB_READ_PORT=5432

# PgBouncer (Connection Pool)
# Application connects to PgBouncer instead of PostgreSQL directly
PGBOUNCER_PORT=6432

# Milvus Vector Database
# Used for: Semantic search, requirement similarity
# Note: In Docker, use service name 'milvus' instead of localhost
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

# ------------------------------------------------------------------------------
# AI/LLM - Language Model Configuration
# ------------------------------------------------------------------------------

# LLM provider.
# LiteLLM is the only supported runtime boundary. It provides OpenAI-compatible
# routing across OpenAI, Anthropic, Gemini, OpenRouter, Ollama, and others.
LLM_PROVIDER=litellm                             # deprecated switch; keep litellm

# Anthropic Claude API [optional; required only for anthropic/* LiteLLM models]
# Get your key at: https://console.anthropic.com/
# <your-anthropic-api-key>
ANTHROPIC_API_KEY=

# Model Selection
# LiteLLM model names use provider/model format, for example:
# openai/gpt-5, anthropic/claude-sonnet-4-20250514, openrouter/google/gemini-2.5-pro
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
CHAT_MODEL=anthropic/claude-sonnet-4-20250514
SUMMARY_MODEL=anthropic/claude-haiku-4-5-20251001
# Optional LiteLLM/provider proxy base URL
LITELLM_API_BASE=
# Required for OpenAI models or LiteLLM proxy auth
OPENAI_API_KEY=
# Required for OpenRouter models
OPENROUTER_API_KEY=
# Required for Gemini models through LiteLLM
GEMINI_API_KEY=
# Alternate Google provider key used by some LiteLLM routes
GOOGLE_API_KEY=

# Cost Controls (USD)
# Prevents runaway API costs; set based on your budget
LLM_DAILY_BUDGET_USD=10.0                       # Daily spending limit
LLM_MONTHLY_BUDGET_USD=200.0                    # Monthly spending limit

# Control Plane (SPEC ledger)
# Disabled by default for local compatibility. Production must enable the
# ledger and approval enforcement after applying migrations.
CONTROL_PLANE_ENABLED=false
CONTROL_PLANE_COMPANY_ID=cmp_projectcell
CONTROL_PLANE_APPROVAL_ENFORCED=false
CONTROL_PLANE_LLM_BUDGET_ENFORCED=false
CONTROL_PLANE_LLM_BUDGET_SCOPE=agent            # company | goal | agent | work_item
CONTROL_PLANE_LLM_BUDGET_PERIOD=daily           # daily | monthly | quarterly | total
CONTROL_PLANE_TOOL_BUDGET_ENFORCED=false
CONTROL_PLANE_TOOL_BUDGET_SCOPE=agent           # company | goal | agent | work_item
CONTROL_PLANE_TOOL_BUDGET_PERIOD=daily          # daily | monthly | quarterly | total
CONTROL_PLANE_LOCAL_ADAPTER_ENABLED=false       # Enables process/codex_local/claude_local adapters
# Comma-separated exact entries, e.g. process:ops-runner
CONTROL_PLANE_LOCAL_ADAPTER_ALLOWLIST=

# ------------------------------------------------------------------------------
# INTEGRATIONS - Third-party Services (Optional)
# ------------------------------------------------------------------------------

# Feishu (Lark) Integration
# Used for: Meeting import webhook, notifications
# Setup: https://open.feishu.cn/
# Webhook URL for notifications
FEISHU_WEBHOOK_URL=
# App ID for API access
FEISHU_APP_ID=
# App Secret (keep secure!)
FEISHU_APP_SECRET=

# === Feishu advanced integration ===
# Get these values from the Feishu developer console: https://open.feishu.cn/app
# FEISHU_ENCRYPT_KEY=xxxxx                       # Event-subscription encryption key
# FEISHU_VERIFICATION_TOKEN=xxxxx                # Event-subscription verification token
# FEISHU_VERIFY_SIGNATURE=true                   # Verify request signatures
# FEISHU_ENABLED=false                           # Enable advanced Feishu integration
# FEISHU_BOT_ENABLED=true                        # Enable bot message handling
# FEISHU_EVENT_ENABLED=true                      # Enable event subscriptions
# FEISHU_CARD_ENABLED=true                       # Enable interactive-card callbacks
# FEISHU_DEFAULT_CHAT_ID=oc_xxxxx                # Default notification chat ID

# === Feishu message recording ===
# Used to record group-chat messages and extract requirements automatically.
# Note: requires the im:message permission to receive all group messages.
# FEISHU_MESSAGE_RECORDING_ENABLED=false          # Enable message recording
# FEISHU_MONITORED_CHAT_IDS_RAW=oc_xxx,oc_yyy    # Allowlisted chat IDs, comma-separated
# FEISHU_SESSION_TIMEOUT=300                      # Session timeout in seconds, default 5 minutes
# FEISHU_MIN_MESSAGES_TO_EXTRACT=5                # Minimum messages before extraction

# === PM System Agent Configuration ===
# API key for internal service API authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# [REQUIRED in production] API key for service endpoints
PM_API_KEY=

# Feishu PM Integration
# FEISHU_PM_APP_TOKEN=                               # Feishu Bitable app token
# FEISHU_PM_TASK_TABLE_ID=                           # Task table ID
# FEISHU_PM_MEMBER_TABLE_ID=                         # Member table ID
# FEISHU_PM_PROJECT_TABLE_ID=                        # Project table ID
# FEISHU_PM_RULES_TABLE_ID=                          # Rules table ID
# FEISHU_REPORT_CHAT_ID=                             # Report destination chat ID

# OpenProject Integration
# OPENPROJECT_URL=http://localhost:8080              # OpenProject base URL
# OPENPROJECT_API_KEY=                               # OpenProject API key

# Sync Module Configuration
# SYNC_MODULE_HOST=sync-module                       # Sync module hostname
# SYNC_MODULE_PORT=8010                              # Sync module port
# Deprecated aliases still load: SYNC_AGENT_HOST, SYNC_AGENT_PORT

# ============ WeCom configuration ============
# Get these values from the WeCom admin console: https://work.weixin.qq.com/
WECOM_ENABLED=false                              # Enable WeCom integration
# Enterprise ID
WECOM_CORP_ID=
# Application AgentId
WECOM_AGENT_ID=
# Application secret
WECOM_SECRET=
# WeCom API base URL used by gateway outbound replies
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com/cgi-bin
# Callback token for request verification
WECOM_TOKEN=
# Callback EncodingAESKey for message encryption
WECOM_ENCODING_AES_KEY=
WECOM_BOT_ENABLED=true                           # Enable bot message handling
WECOM_CARD_ENABLED=true                          # Enable card callbacks

# ------------------------------------------------------------------------------
# APPLICATION - Runtime Configuration
# ------------------------------------------------------------------------------

# Environment
APP_NAME=Wisdoverse Cell
APP_ENV=development                             # development | staging | production
DEBUG=true                                      # Disable in production!

# API Server
API_HOST=0.0.0.0                                # 0.0.0.0 for container, 127.0.0.1 for local only
API_PORT=8000

# Service Ports (Docker Compose)
AI_CORE_HTTP_PORT=8000                          # Requirements capability HTTP API (ai-core runtime id)
AI_CORE_GRPC_PORT=50051                         # Requirements capability gRPC (ai-core runtime id)
GATEWAY_PORT=8080                               # Gateway HTTP (Rust)
# Dedicated production gateway host for health, ready, and webhook evidence.
# [REQUIRED in production]
GATEWAY_HOST=
RUST_GATEWAY_SHADOW_PORT=18080                  # Rust gateway shadow listener for canary checks
# RUST_GATEWAY_SHADOW_HOST=rust-gateway.prod.company.com  # Replace with the real production shadow host
# LEGACY_GATEWAY_URL=https://gateway.prod.company.com         # Replace with the real baseline gateway URL for shadow checks
# RUST_GATEWAY_URL=https://gateway.prod.company.com           # Replace with the real Rust gateway URL
# RUST_GATEWAY_LOCAL_EVIDENCE_REPORT=.artifacts/rust-gateway-local-shadow-check.json
# RUST_GATEWAY_PROD_EVIDENCE_REPORT=.artifacts/rust-gateway-prod-shadow-check.json
SYNC_MODULE_PORT=8010                           # Sync support capability HTTP API
ANALYSIS_MODULE_PORT=8011                        # Analysis support capability HTTP API
PM_AGENT_PORT=8012                              # PJM agent HTTP API
CHAT_AGENT_PORT=8013                            # User interaction gateway HTTP API
QA_AGENT_PORT=8014                              # QA agent HTTP API
DEV_AGENT_PORT=8015                             # Dev agent HTTP API
EVOLUTION_MODULE_PORT=8016                      # Evolution support capability HTTP API
MILVUS_PORT=19530                              # Milvus gRPC/API
MILVUS_HEALTH_PORT=9091                        # Milvus health endpoint

# ------------------------------------------------------------------------------
# GATEWAY - Configuration
# ------------------------------------------------------------------------------

GATEWAY_MODE=release                            # debug | release | test
RATELIMIT_ENABLED=true                          # Enable rate limiting
RATELIMIT_RPS=100                               # Requests per second
RATELIMIT_BURST=200                             # Burst size
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn/open-apis  # Feishu Open API base URL

# ------------------------------------------------------------------------------
# OBSERVABILITY - Monitoring (Optional)
# ------------------------------------------------------------------------------
# Use with: make monitoring-up  (or  make up-prod  which includes observability)

OTEL_ENDPOINT=http://tempo:4317                 # OpenTelemetry collector (Tempo)
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json                                 # json | console

# Sentry Error Tracking (Optional)
# Sentry DSN for frontend error tracking
NEXT_PUBLIC_SENTRY_DSN=
# Sentry auth token for source map upload
SENTRY_AUTH_TOKEN=
# SENTRY_ORG=                                   # Sentry organization slug
# SENTRY_PROJECT=                               # Sentry project slug


# Grafana
GRAFANA_ADMIN_USER=admin                        # Grafana admin username
GRAFANA_ADMIN_PASSWORD=projectcell              # Grafana admin password (change in prod!)

# ------------------------------------------------------------------------------
# SECURITY - Authentication & Encryption
# ------------------------------------------------------------------------------

# Secret Key [REQUIRED in production]
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-only-change-in-production        # [REQUIRED] Change in production!
# [REQUIRED in production] Shared service-to-service key
INTERNAL_SERVICE_KEY=
# [REQUIRED in production] trusted_private_network | service_mesh | mtls
INTERNAL_TRANSPORT_PROTECTION=
A2A_JWT_SECRET=dev-only-change-in-production    # [REQUIRED in production] A2A token signing secret

# ── Frontend ──────────────────────────────────────────────
WEB_REPLICAS=2
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# NextAuth Secret [REQUIRED in production]
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-only-change-in-production

# Default credentials (development and controlled preview only)
# Set to "true" to enable username/password login.
# Keep username/password empty in version control; set them in .env or deployment secrets.
ENABLE_DEV_AUTH=false
DEV_AUTH_USERNAME=
DEV_AUTH_PASSWORD=
DEV_AUTH_ROLE=admin
DEV_AUTH_DISPLAY_NAME=Dev

# Feishu OAuth (for production SSO)
# AUTH_FEISHU_APP_ID=
# AUTH_FEISHU_APP_SECRET=

# WeCom OAuth (for production SSO)
# AUTH_WECOM_CORP_ID=
# AUTH_WECOM_AGENT_ID=
# AUTH_WECOM_SECRET=

# ------------------------------------------------------------------------------
# VERIFICATION
# ------------------------------------------------------------------------------
# After configuration, verify with:
#   source .venv/bin/activate
#   python -c "from shared.config import settings; print(f'DB: {settings.postgres_host}:{settings.postgres_port}/{settings.postgres_db}')"
