# ==============================================================================
# Wisdoverse Cell - Environment Configuration
# ==============================================================================
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Fill in required values (marked with [REQUIRED])
#   3. Adjust optional values as needed
#   4. Start services: docker compose up -d
#
# Environments:
#   - development: Local development with debug enabled
#   - staging:     Pre-production testing
#   - production:  Live environment (never commit .env for this!)
#
# Security:
#   - NEVER commit .env files to version control
#   - Use secrets management (Vault, AWS Secrets Manager) in production
#   - Rotate credentials regularly
#
# ==============================================================================

# ------------------------------------------------------------------------------
# DOCKER COMPOSE - Container Configuration
# ------------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=projectcell
VERSION=latest
REGISTRY=                                           # Optional: Docker registry prefix

# ------------------------------------------------------------------------------
# BUILD MIRRORS - CN acceleration (leave empty for international defaults)
# ------------------------------------------------------------------------------
# For China mainland, copy values from:
#   docs/examples/cn-build-mirrors.env.example
#
# PIP_INDEX_URL=                                    # CN: https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=                                 # CN: pypi.tuna.tsinghua.edu.cn
# APT_MIRROR=                                       # CN: mirrors.aliyun.com
# ALPINE_MIRROR=                                    # CN: mirrors.aliyun.com
# GOPROXY=                                          # CN: https://goproxy.cn,direct
# NPM_REGISTRY=                                     # CN: https://registry.npmmirror.com

# Replica Configuration
AI_CORE_REPLICAS=3                                  # Number of requirement manager agent instances (ai-core runtime id)
GATEWAY_REPLICAS=3                                  # Number of Gateway instances

# Ports (Cloud-Native)
HTTP_PORT=80                                        # Traefik HTTP entry
GRPC_PORT=50051                                     # Traefik gRPC entry

# ------------------------------------------------------------------------------
# INFRASTRUCTURE - External Services
# ------------------------------------------------------------------------------

# PostgreSQL Database [REQUIRED]
# Local: localhost | Docker: host.docker.internal | Production: your-db-host
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=projectcell
POSTGRES_USER=cell
POSTGRES_PASSWORD=                              # [REQUIRED] Set a strong password
POSTGRES_REPLICATION_PASSWORD=replicator        # Replication user password (change in prod!)

# Redis Cache & Message Queue
# Used for: Event bus, session cache, rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                                 # Leave empty if no auth required

# Event Bus Backend
EVENT_BUS_BACKEND=redis                        # "nats" | "redis" (default: redis)
EVENT_BUS_CONSUMER_NAME=                       # NATS durable consumer name; defaults to OTEL_SERVICE_NAME
EVENT_BUS_PENDING_CLAIM_IDLE_MS=360000         # Redis Streams: reclaim pending messages idle for this long
EVENT_BUS_PENDING_CLAIM_COUNT=10               # Redis Streams: max pending messages reclaimed per poll
EVENT_BUS_PROCESSED_EVENT_TTL_SECONDS=604800   # Redis Streams: remember processed event IDs for replay idempotency
EVENT_BUS_PROCESSING_LOCK_TTL_SECONDS=360      # Redis Streams: in-flight event lock TTL

# NATS JetStream (Event Bus)
# Used for: Event-driven communication between agents
NATS_URL=nats://nats-1:4222,nats://nats-2:4222,nats://nats-3:4222
NATS_STREAM_REPLICAS=3                         # Use 1 for single-node local NATS

# Database Read Replica (optional, for read/write split)
# DB_READ_HOST=pg-replica                      # Set to enable read replica routing
# DB_READ_PORT=5432

# PgBouncer (Connection Pool)
# Application connects to PgBouncer instead of PostgreSQL directly
PGBOUNCER_PORT=6432

# Milvus Vector Database
# Used for: Semantic search, requirement similarity
# Note: In Docker, use service name 'milvus' instead of localhost
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=

# ------------------------------------------------------------------------------
# AI/LLM - Language Model Configuration
# ------------------------------------------------------------------------------

# LLM provider.
# LiteLLM is the only supported runtime boundary. It provides OpenAI-compatible
# routing across OpenAI, Anthropic, Gemini, OpenRouter, Ollama, and others.
LLM_PROVIDER=litellm                             # deprecated switch; keep litellm

# Anthropic Claude API [optional; required only for anthropic/* LiteLLM models]
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=                              # <your-anthropic-api-key>

# Model Selection
# LiteLLM model names use provider/model format, for example:
# openai/gpt-5, anthropic/claude-sonnet-4-20250514, openrouter/google/gemini-2.5-pro
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
CHAT_MODEL=anthropic/claude-sonnet-4-20250514
SUMMARY_MODEL=anthropic/claude-haiku-4-5-20251001
LITELLM_API_BASE=                               # Optional LiteLLM/provider proxy base URL
OPENAI_API_KEY=                                 # Required for OpenAI models or LiteLLM proxy auth
OPENROUTER_API_KEY=                             # Required for OpenRouter models
GEMINI_API_KEY=                                 # Required for Gemini models through LiteLLM
GOOGLE_API_KEY=                                 # Alternate Google provider key used by some LiteLLM routes

# Cost Controls (USD)
# Prevents runaway API costs; set based on your budget
LLM_DAILY_BUDGET_USD=10.0                       # Daily spending limit
LLM_MONTHLY_BUDGET_USD=200.0                    # Monthly spending limit

# Control Plane (SPEC ledger)
# Disabled by default for local compatibility. Production must enable the
# ledger and approval enforcement after applying migrations.
CONTROL_PLANE_ENABLED=false
CONTROL_PLANE_COMPANY_ID=cmp_projectcell
CONTROL_PLANE_APPROVAL_ENFORCED=false
CONTROL_PLANE_LLM_BUDGET_ENFORCED=false
CONTROL_PLANE_LLM_BUDGET_SCOPE=agent            # company | goal | agent | work_item
CONTROL_PLANE_LLM_BUDGET_PERIOD=daily           # daily | monthly | quarterly | total
CONTROL_PLANE_TOOL_BUDGET_ENFORCED=false
CONTROL_PLANE_TOOL_BUDGET_SCOPE=agent           # company | goal | agent | work_item
CONTROL_PLANE_TOOL_BUDGET_PERIOD=daily          # daily | monthly | quarterly | total
CONTROL_PLANE_LOCAL_ADAPTER_ENABLED=false       # Enables process/codex_local/claude_local adapters
CONTROL_PLANE_LOCAL_ADAPTER_ALLOWLIST=          # Comma-separated exact entries, e.g. process:ops-runner

# ------------------------------------------------------------------------------
# INTEGRATIONS - Third-party Services (Optional)
# ------------------------------------------------------------------------------

# Feishu (Lark) Integration
# Used for: Meeting import webhook, notifications
# Setup: https://open.feishu.cn/
FEISHU_WEBHOOK_URL=                             # Webhook URL for notifications
FEISHU_APP_ID=                                  # App ID for API access
FEISHU_APP_SECRET=                              # App Secret (keep secure!)

# === 飞书深度集成 ===
# 从飞书开放平台获取：https://open.feishu.cn/app
# FEISHU_ENCRYPT_KEY=xxxxx                       # 事件订阅加密密钥
# FEISHU_VERIFICATION_TOKEN=xxxxx                # 事件订阅验证令牌
# FEISHU_VERIFY_SIGNATURE=true                   # 是否验证请求签名
# FEISHU_ENABLED=false                           # 是否启用飞书深度集成
# FEISHU_BOT_ENABLED=true                        # 是否启用 Bot 消息处理
# FEISHU_EVENT_ENABLED=true                      # 是否启用事件订阅
# FEISHU_CARD_ENABLED=true                       # 是否启用卡片回调
# FEISHU_DEFAULT_CHAT_ID=oc_xxxxx                # 默认通知群 ID

# === 飞书消息记录配置 ===
# 用于自动记录群聊消息并提取需求
# 注意：需要申请 im:message 权限以接收群内所有消息
# FEISHU_MESSAGE_RECORDING_ENABLED=false          # 是否启用消息记录
# FEISHU_MONITORED_CHAT_IDS_RAW=oc_xxx,oc_yyy    # 白名单群聊ID（逗号分隔）
# FEISHU_SESSION_TIMEOUT=300                      # 会话超时时间（秒），默认5分钟
# FEISHU_MIN_MESSAGES_TO_EXTRACT=5                # 触发提取的最少消息数

# === PM System Agent Configuration ===
# API key for inter-agent API authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PM_API_KEY=                                         # [REQUIRED in production] API key for agent endpoints

# Feishu PM Integration
# FEISHU_PM_APP_TOKEN=                               # 飞书多维表格 App Token
# FEISHU_PM_TASK_TABLE_ID=                           # 任务表 Table ID
# FEISHU_PM_MEMBER_TABLE_ID=                         # 成员表 Table ID
# FEISHU_PM_PROJECT_TABLE_ID=                        # 项目表 Table ID
# FEISHU_PM_RULES_TABLE_ID=                          # 规则表 Table ID
# FEISHU_REPORT_CHAT_ID=                             # 报告推送群 Chat ID

# OpenProject Integration
# OPENPROJECT_URL=http://localhost:8080              # OpenProject base URL
# OPENPROJECT_API_KEY=                               # OpenProject API key

# Sync Agent Configuration
# SYNC_AGENT_HOST=sync-agent                         # Sync agent hostname
# SYNC_AGENT_PORT=8002                               # Sync agent port

# ============ 企业微信配置 ============
# 从企业微信管理后台获取：https://work.weixin.qq.com/
WECOM_ENABLED=false                              # 是否启用企业微信集成
WECOM_CORP_ID=                                   # 企业 ID
WECOM_AGENT_ID=                                  # 应用 AgentId
WECOM_SECRET=                                    # 应用 Secret
WECOM_TOKEN=                                     # 回调 Token（用于验证请求）
WECOM_ENCODING_AES_KEY=                          # 回调 EncodingAESKey（消息加解密）
WECOM_BOT_ENABLED=true                           # 是否启用 Bot 消息处理
WECOM_CARD_ENABLED=true                          # 是否启用卡片回调

# ------------------------------------------------------------------------------
# APPLICATION - Runtime Configuration
# ------------------------------------------------------------------------------

# Environment
APP_NAME=Wisdoverse Cell
APP_ENV=development                             # development | staging | production
DEBUG=true                                      # Disable in production!

# API Server
API_HOST=0.0.0.0                                # 0.0.0.0 for container, 127.0.0.1 for local only
API_PORT=8000

# Service Ports (Docker Compose)
AI_CORE_HTTP_PORT=8000                          # Requirements capability HTTP API (ai-core runtime id)
AI_CORE_GRPC_PORT=50051                         # Requirements capability gRPC (ai-core runtime id)
GATEWAY_PORT=8080                               # Go Gateway HTTP
MILVUS_PORT=19530                              # Milvus gRPC/API
MILVUS_HEALTH_PORT=9091                        # Milvus health endpoint

# ------------------------------------------------------------------------------
# GO GATEWAY - Configuration
# ------------------------------------------------------------------------------

GATEWAY_MODE=release                            # debug | release | test
RATELIMIT_ENABLED=true                          # Enable rate limiting
RATELIMIT_RPS=100                               # Requests per second
RATELIMIT_BURST=200                             # Burst size

# ------------------------------------------------------------------------------
# OBSERVABILITY - Monitoring (Optional)
# ------------------------------------------------------------------------------
# Use with: make monitoring-up  (or  make up-prod  which includes observability)

OTEL_ENDPOINT=http://tempo:4317                 # OpenTelemetry collector (Tempo)
LOG_LEVEL=INFO                                  # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json                                 # json | console

# Sentry Error Tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN=                         # Sentry DSN for frontend error tracking
SENTRY_AUTH_TOKEN=                              # Sentry auth token for source map upload
# SENTRY_ORG=                                   # Sentry organization slug
# SENTRY_PROJECT=                               # Sentry project slug


# Grafana
GRAFANA_ADMIN_USER=admin                        # Grafana admin username
GRAFANA_ADMIN_PASSWORD=projectcell              # Grafana admin password (change in prod!)

# ------------------------------------------------------------------------------
# SECURITY - Authentication & Encryption
# ------------------------------------------------------------------------------

# Secret Key [REQUIRED in production]
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-only-change-in-production        # [REQUIRED] Change in production!
INTERNAL_SERVICE_KEY=                           # [REQUIRED in production] Shared service-to-service key
A2A_JWT_SECRET=dev-only-change-in-production    # [REQUIRED in production] A2A token signing secret

# ── Frontend ──────────────────────────────────────────────
WEB_REPLICAS=2
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# NextAuth Secret [REQUIRED in production]
# Generate with: openssl rand -base64 32
AUTH_SECRET=dev-only-change-in-production

# Dev Credentials (development only)
# Set to "true" to enable username/password login for local development
ENABLE_DEV_AUTH=true

# Feishu OAuth (for production SSO)
# AUTH_FEISHU_APP_ID=
# AUTH_FEISHU_APP_SECRET=

# WeCom OAuth (for production SSO)
# AUTH_WECOM_CORP_ID=
# AUTH_WECOM_AGENT_ID=
# AUTH_WECOM_SECRET=

# ------------------------------------------------------------------------------
# VERIFICATION
# ------------------------------------------------------------------------------
# After configuration, verify with:
#   source .venv/bin/activate
#   python -c "from shared.config import settings; print(f'DB: {settings.postgres_host}:{settings.postgres_port}/{settings.postgres_db}')"
